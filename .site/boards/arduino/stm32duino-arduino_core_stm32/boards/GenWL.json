{
  "build": {
    "board": "GenWL",
    "core": "arduino",
    "flash_offset": "0x0",
    "mcu": "cortex-m4",
    "series": "STM32WLxx",
    "st_extra_flags": "-D{build.product_line} -DUSE_CM4_STARTUP_FILE {build.xSerial}"
  },
  "menu": {
    "dbg": {
      "enable_all": {
        "": "Core Logs and Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g"
          }
        }
      },
      "enable_log": {
        "": "Core logs Enabled",
        "build": {
          "flags": {
            "debug": ""
          }
        }
      },
      "enable_sym": {
        "": "Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g -DNDEBUG"
          }
        }
      },
      "none": "None"
    },
    "opt": {
      "o0std": {
        "": "No Optimization (-O0)",
