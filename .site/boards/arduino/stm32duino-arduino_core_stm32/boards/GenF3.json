{
  "build": {
    "board": "GenF3",
    "core": "arduino",
    "flash_offset": "0x0",
    "float-abi": "-mfloat-abi=hard",
    "fpu": "-mfpu=fpv4-sp-d16",
    "mcu": "cortex-m4",
    "series": "STM32F3xx",
