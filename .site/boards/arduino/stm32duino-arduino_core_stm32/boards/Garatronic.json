{
  "build": {
    "board": "Garatronic",
    "core": "arduino",
    "family": "GARATRONIC",
    "flash_offset": "0x0",
    "st_extra_flags": "-D{build.product_line} {build.enable_usb} {build.xSerial}",
    "variant_h": "variant_{build.board}.h"
  },
  "menu": {
    "dbg": {
      "enable_all": {
        "": "Core Logs and Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g"
          }
        }
      },
      "enable_log": {
        "": "Core logs Enabled",
        "build": {
          "flags": {
            "debug": ""
          }
        }
      },
      "enable_sym": {
        "": "Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g -DNDEBUG"
          }
        }
      },
      "none": "None"
    },
    "opt": {
      "o0std": {
        "": "No Optimization (-O0)",
        "build": {
          "flags": {
            "optimize": "-O0"
          }
        }
      },
      "o1lto": {
        "": "Fast (-O1) with LTO",
        "build": {
          "flags": {
            "optimize": "-O1 -flto"
          }
        }
      },
      "o1std": {
        "": "Fast (-O1)",
        "build": {
          "flags": {
            "optimize": "-O1"
          }
        }
      },
      "o2lto": {
        "": "Faster (-O2) with LTO",
        "build": {
          "flags": {
            "optimize": "-O2 -flto"
          }
        }
      },
      "o2std": {
        "": "Faster (-O2)",
        "build": {
          "flags": {
            "optimize": "-O2"
          }
        }
      },
      "o3lto": {
        "": "Fastest (-O3) with LTO",
        "build": {
          "flags": {
            "optimize": "-O3 -flto"
          }
        }
      },
      "o3std": {
        "": "Fastest (-O3)",
        "build": {
          "flags": {
            "optimize": "-O3"
          }
        }
      },
      "ogstd": {
        "": "Debug (-Og)",
        "build": {
          "flags": {
            "optimize": "-Og"
          }
        }
      },
      "oslto": {
        "": "Smallest (-Os) with LTO",
        "build": {
          "flags": {
            "optimize": "-Os -flto"
          }
        }
      },
      "osstd": "Smallest (-Os default)"
    },
    "pnum": {
      "PYBSTICK26_DUINO": {
        "": "PYBSTICK26 Duino",
        "build": {
          "board": "PYBSTICK26_DUINO",
          "mcu": "cortex-m0",
          "peripheral_pins": "-DCUSTOM_PERIPHERAL_PINS",
          "product_line": "STM32F072xB",
          "series": "STM32F0xx",
          "variant": "STM32F0xx/F072R8T_F072RB(H-I-T)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32F0xx/STM32F0x2.svd"
        },
        "openocd": {
          "target": "stm32f0x"
        },
        "upload": {
          "maximum_data_size": "16384",
          "maximum_size": "131072"
        }
      },
      "PYBSTICK26_LITE": {
        "": "PYBSTICK26 Lite",
        "build": {
          "board": "PYBSTICK26_LITE",
          "float-abi": "-mfloat-abi=hard",
          "fpu": "-mfpu=fpv4-sp-d16",
          "mcu": "cortex-m4",
          "peripheral_pins": "-DCUSTOM_PERIPHERAL_PINS",
          "product_line": "STM32F401xE",
          "series": "STM32F4xx",
          "variant": "STM32F4xx/F401CC(F-U-Y)_F401C(B-D-E)(U-Y)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32F4xx/STM32F401.svd"
        },
        "openocd": {
          "target": "stm32f4x"
        },
        "upload": {
          "maximum_data_size": "98304",
          "maximum_size": "524288"
        }
      },
      "PYBSTICK26_PRO": {
        "": "PYBSTICK26 Pro",
        "build": {
          "board": "PYBSTICK26_PRO",
          "float-abi": "-mfloat-abi=hard",
          "fpu": "-mfpu=fpv4-sp-d16",
          "mcu": "cortex-m4",
          "peripheral_pins": "-DCUSTOM_PERIPHERAL_PINS",
          "product_line": "STM32F412Rx",
          "series": "STM32F4xx",
          "variant": "STM32F4xx/F412R(E-G)(T-Y)x(P)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32F4xx/STM32F412.svd"
        },
        "openocd": {
          "target": "stm32f4x"
        },
        "upload": {
          "maximum_data_size": "262144",
          "maximum_size": "524288"
        }
      },
      "PYBSTICK26_STD": {
        "": "PYBSTICK26 STD-Programmez",
        "build": {
          "board": "PYBSTICK26_STD",
          "float-abi": "-mfloat-abi=hard",
          "fpu": "-mfpu=fpv4-sp-d16",
          "mcu": "cortex-m4",
          "peripheral_pins": "-DCUSTOM_PERIPHERAL_PINS",
          "product_line": "STM32F411xE",
          "series": "STM32F4xx",
          "variant": "STM32F4xx/F411R(C-E)T"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32F4xx/STM32F411.svd"
        },
        "openocd": {
          "target": "stm32f4x"
        },
        "upload": {
          "maximum_data_size": "131072",
          "maximum_size": "524288"
        }
      }
    },
    "rtlib": {
      "full": {
        "": "Newlib Standard",
        "build": {
          "flags": {
            "ldspecs": ""
          }
        }
      },
      "nano": "Newlib Nano (default)",
      "nanofp": {
        "": "Newlib Nano + Float Printf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float"
          }
        }
      },
      "nanofps": {
        "": "Newlib Nano + Float Printf/Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float -u _scanf_float"
          }
        }
      },
      "nanofs": {
        "": "Newlib Nano + Float Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _scanf_float"
          }
        }
      }
    },
    "upload_method": {
      "dfuMethod": {
        "": "STM32CubeProgrammer (DFU)",
        "upload": {
          "options": "-v {upload.vid} -p {upload.pid} -a {upload.address} -s {upload.start}",
          "protocol": "dfu",
          "tool": "stm32CubeProg"
        }
      }
    },
    "usb": {
      "CDC": {
        "": "CDC (no generic 'Serial')",
        "build": {
          "enable_usb": "{build.usb_flags} -DUSBD_USE_CDC -DDISABLE_GENERIC_SERIALUSB"
        }
      },
      "CDCgen": {
        "": "CDC (generic 'Serial' supersede U(S)ART)",
        "build": {
          "enable_usb": "{build.usb_flags} -DUSBD_USE_CDC"
        }
      },
      "HID": {
        "": "HID (keyboard and mouse)",
        "build": {
          "enable_usb": "{build.usb_flags} -DUSBD_USE_HID_COMPOSITE"
        }
      },
      "none": "None"
    },
    "xserial": {
      "disabled": {
        "": "Disabled (no Serial support)",
        "build": {
          "xSerial": ""
        }
      },
      "generic": "Enabled (generic 'Serial')",
      "none": {
        "": "Enabled (no generic 'Serial')",
        "build": {
          "xSerial": "-DHAL_UART_MODULE_ENABLED -DHWSERIAL_NONE"
        }
      }
    }
  },
  "name": "Garatronic-McHobby",
  "pid": {
    "0": "0x5740"
  },
  "upload": {
    "maximum_data_size": "0",
    "maximum_size": "0"
  },
  "vid": {
    "0": "0x0483"
  }
}
