    "upload_method": {
      "OpenOCDDapLink": {
        "": "OpenOCD DapLink (SWD)",
        "debug": {
          "server": {
            "openocd": {
              "scripts": {
                "0": "interface/cmsis-dap.cfg",
                "1": "{runtime.platform.path}/debugger/select_swd.cfg"
              }
            }
          }
        },
        "upload": {
          "protocol": "cmsis-dap",
          "tool": "openocd_upload"
        }
      },
      "OpenOCDSTLink": {
        "": "OpenOCD STLink (SWD)",
        "upload": {
          "protocol": "stlink",
          "tool": "openocd_upload"
        }
      },
      "bmpMethod": {
        "": "BMP (Black Magic Probe)",
        "upload": {
          "protocol": "gdb_bmp",
          "tool": "bmp_upload"
        }
      },
      "dfu2Method": {
        "": "Maple DFU Bootloader 2.0",
        "build": {
          "bootloader_flags": "-DBL_LEGACY_LEAF",
          "flash_offset": "0x2000"
        },
        "upload": {
          "altID": "2",
          "protocol": "maple",
          "tool": "maple_upload"
        }
      },
      "dfuMethod": {
        "": "STM32CubeProgrammer (DFU)",
        "upload": {
          "options": "-v {upload.vid} -p {upload.pid} -a {upload.address} -s {upload.start}",
          "protocol": "dfu",
          "tool": "stm32CubeProg"
        }
      },
      "dfuoMethod": {
        "": "Maple DFU Bootloader original",
        "build": {
          "bootloader_flags": "-DBL_LEGACY_LEAF",
          "flash_offset": "0x5000"
        },
        "upload": {
          "altID": "1",
          "protocol": "maple",
          "tool": "maple_upload"
        }
      },
      "hidMethod": {
        "": "HID Bootloader 2.2",
        "build": {
          "bootloader_flags": "-DBL_HID",
          "flash_offset": "0x800"
        },
        "upload": {
          "protocol": "hid22",
          "tool": "hid_upload"
        }
      },
      "jlinkMethod": {
        "": "STM32CubeProgrammer (J-Link)",
        "upload": {
          "options": "-a {upload.address} -s {upload.start}",
          "protocol": "jlink",
          "tool": "stm32CubeProg"
        }
      },
      "serialMethod": {
        "": "STM32CubeProgrammer (Serial)",
        "upload": {
          "options": "-c {serial.port.file} -a {upload.address} -s {upload.start} --parity {upload.parity}",
          "protocol": "serial",
          "tool": "stm32CubeProg"
        }
      },
      "swdMethod": {
        "": "STM32CubeProgrammer (SWD)",
        "upload": {
          "options": "-a {upload.address} -m {upload.mode} -s {upload.start}",
          "protocol": "swd",
          "tool": "stm32CubeProg"
        }
      }
    },
