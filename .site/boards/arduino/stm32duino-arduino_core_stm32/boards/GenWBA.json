{
  "build": {
    "board": "GenWBA",
    "core": "arduino",
    "flash_offset": "0x0",
    "float-abi": "-mfloat-abi=hard",
    "fpu": "-mfpu=fpv5-sp-d16",
    "mcu": "cortex-m33",
    "series": "STM32WBAxx",
    "st_extra_flags": "-D{build.product_line} {build.xSerial}"
  },
  "menu": {
    "dbg": {
      "enable_all": {
        "": "Core Logs and Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g"
          }
        }
      },
      "enable_log": {
        "": "Core logs Enabled",
        "build": {
          "flags": {
            "debug": ""
          }
        }
      },
      "enable_sym": {
        "": "Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g -DNDEBUG"
          }
        }
      },
      "none": "None"
    },
    "opt": {
      "o0std": {
        "": "No Optimization (-O0)",
        "build": {
          "flags": {
            "optimize": "-O0"
          }
        }
      },
      "o1lto": {
        "": "Fast (-O1) with LTO",
        "build": {
          "flags": {
            "optimize": "-O1 -flto"
          }
        }
      },
      "o1std": {
        "": "Fast (-O1)",
        "build": {
          "flags": {
            "optimize": "-O1"
          }
        }
      },
      "o2lto": {
        "": "Faster (-O2) with LTO",
        "build": {
          "flags": {
            "optimize": "-O2 -flto"
          }
        }
      },
      "o2std": {
        "": "Faster (-O2)",
        "build": {
          "flags": {
            "optimize": "-O2"
          }
        }
      },
      "o3lto": {
        "": "Fastest (-O3) with LTO",
        "build": {
          "flags": {
            "optimize": "-O3 -flto"
          }
        }
      },
      "o3std": {
        "": "Fastest (-O3)",
        "build": {
          "flags": {
            "optimize": "-O3"
          }
        }
      },
      "ogstd": {
        "": "Debug (-Og)",
        "build": {
          "flags": {
            "optimize": "-Og"
          }
        }
      },
      "oslto": {
        "": "Smallest (-Os) with LTO",
        "build": {
          "flags": {
            "optimize": "-Os -flto"
          }
        }
      },
      "osstd": "Smallest (-Os default)"
    },
    "pnum": {
      "GENERIC_WBA55CEUX": {
        "": "Generic WBA55CEUx",
        "build": {
          "board": "GENERIC_WBA55CEUX",
          "product_line": "STM32WBA55xx",
          "variant": "STM32WBAxx/WBA55C(E-G)U"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WBAxx/STM32WBA55.svd"
        },
        "upload": {
          "maximum_data_size": "98304",
          "maximum_size": "524288"
        }
      },
      "GENERIC_WBA55CGUX": {
        "": "Generic WBA55CGUx",
        "build": {
          "board": "GENERIC_WBA55CGUX",
          "product_line": "STM32WBA55xx",
          "variant": "STM32WBAxx/WBA55C(E-G)U"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WBAxx/STM32WBA55.svd"
        },
        "upload": {
          "maximum_data_size": "131072",
          "maximum_size": "1048576"
        }
      }
    },
    "rtlib": {
      "full": {
        "": "Newlib Standard",
        "build": {
          "flags": {
            "ldspecs": ""
          }
        }
      },
      "nano": "Newlib Nano (default)",
      "nanofp": {
        "": "Newlib Nano + Float Printf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float"
          }
        }
      },
      "nanofps": {
        "": "Newlib Nano + Float Printf/Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float -u _scanf_float"
          }
        }
      },
      "nanofs": {
        "": "Newlib Nano + Float Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _scanf_float"
          }
        }
      }
    },
    "upload_method": {
      "OpenOCDDapLink": {
        "": "OpenOCD DapLink (SWD)",
        "debug": {
          "server": {
            "openocd": {
              "scripts": {
                "0": "interface/cmsis-dap.cfg",
                "1": "{runtime.platform.path}/debugger/select_swd.cfg"
              }
            }
          }
        },
        "upload": {
          "protocol": "cmsis-dap",
          "tool": "openocd_upload"
        }
      },
      "OpenOCDSTLink": {
        "": "OpenOCD STLink (SWD)",
        "upload": {
          "protocol": "stlink",
          "tool": "openocd_upload"
        }
      },
      "jlinkMethod": {
        "": "STM32CubeProgrammer (J-Link)",
        "upload": {
          "options": "-a {upload.address} -s {upload.start}",
          "protocol": "jlink",
          "tool": "stm32CubeProg"
        }
      },
      "serialMethod": {
        "": "STM32CubeProgrammer (Serial)",
        "upload": {
          "options": "-c {serial.port.file} -a {upload.address} -s {upload.start} --parity {upload.parity}",
          "protocol": "serial",
          "tool": "stm32CubeProg"
        }
      },
      "swdMethod": {
        "": "STM32CubeProgrammer (SWD)",
        "upload": {
          "options": "-a {upload.address} -m {upload.mode} -s {upload.start}",
          "protocol": "swd",
          "tool": "stm32CubeProg"
        }
      }
    },
    "xserial": {
      "disabled": {
        "": "Disabled (no Serial support)",
        "build": {
          "xSerial": ""
        }
      },
      "generic": "Enabled (generic 'Serial')",
      "none": {
        "": "Enabled (no generic 'Serial')",
        "build": {
          "xSerial": "-DHAL_UART_MODULE_ENABLED -DHWSERIAL_NONE"
        }
      }
    }
  },
  "name": "Generic STM32WBA series",
  "openocd": {
    "target": "stm32wbax"
  },
  "upload": {
    "maximum_data_size": "0",
    "maximum_size": "0"
  }
}
