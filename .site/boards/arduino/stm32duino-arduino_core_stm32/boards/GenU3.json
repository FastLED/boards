{
  "build": {
    "board": "GenU3",
    "core": "arduino",
    "flash_offset": "0x0",
    "float-abi": "-mfloat-abi=hard",
    "fpu": "-mfpu=fpv5-sp-d16",
    "mcu": "cortex-m33",
    "series": "STM32U3xx",
    "st_extra_flags": "-D{build.product_line} {build.enable_usb} {build.xSerial}"
  },
  "menu": {
    "dbg": {
      "enable_all": {
        "": "Core Logs and Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g"
          }
        }
      },
      "enable_log": {
        "": "Core logs Enabled",
        "build": {
          "flags": {
            "debug": ""
          }
        }
      },
      "enable_sym": {
        "": "Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g -DNDEBUG"
          }
        }
      },
      "none": "None"
    },
    "opt": {
      "o0std": {
        "": "No Optimization (-O0)",
        "build": {
          "flags": {
            "optimize": "-O0"
          }
        }
      },
      "o1lto": {
        "": "Fast (-O1) with LTO",
        "build": {
          "flags": {
            "optimize": "-O1 -flto"
          }
        }
      },
      "o1std": {
        "": "Fast (-O1)",
        "build": {
          "flags": {
            "optimize": "-O1"
          }
        }
      },
      "o2lto": {
        "": "Faster (-O2) with LTO",
        "build": {
          "flags": {
            "optimize": "-O2 -flto"
          }
        }
      },
      "o2std": {
        "": "Faster (-O2)",
        "build": {
          "flags": {
            "optimize": "-O2"
          }
        }
      },
      "o3lto": {
        "": "Fastest (-O3) with LTO",
        "build": {
          "flags": {
            "optimize": "-O3 -flto"
          }
        }
      },
      "o3std": {
        "": "Fastest (-O3)",
        "build": {
          "flags": {
            "optimize": "-O3"
          }
        }
      },
      "ogstd": {
        "": "Debug (-Og)",
        "build": {
          "flags": {
            "optimize": "-Og"
          }
        }
      },
      "oslto": {
        "": "Smallest (-Os) with LTO",
        "build": {
          "flags": {
            "optimize": "-Os -flto"
          }
        }
      },
      "osstd": {
        "": "Smallest (-Os default)",
        "build": {
          "flags": {
            "optimize": "-Os"
          }
        }
      }
    },
    "pnum": {
      "GENERIC_U375RETXQ": {
        "": "Generic U375RETxQ",
        "build": {
          "board": "GENERIC_U375RETXQ",
          "product_line": "STM32U375xx",
          "variant": "STM32U3xx/U375R(E-G)TxQ_U385RGTxQ"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32U3xx/STM32U375.svd"
        },
        "upload": {
          "maximum_data_size": "262144",
