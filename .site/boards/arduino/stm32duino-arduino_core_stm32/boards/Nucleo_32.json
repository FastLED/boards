{
  "build": {
    "board": "Nucleo_32",
    "core": "arduino",
    "family": "NUCLEO_32",
    "flash_offset": "0x0",
    "st_extra_flags": "-D{build.product_line} {build.enable_usb} {build.xSerial}",
    "variant_h": "variant_{build.board}.h"
