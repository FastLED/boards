{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "AMYBOARD",
    "boot": "qio",
    "boot_freq": "120m",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "0",
    "core": "esp32",
    "defines": "-DBOARD_HAS_PSRAM -DAMYBOARD_ARDUINO",
    "dfu_on_boot": "0",
    "event_core": "",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "16MB",
    "loop_core": "",
    "mcu": "esp32s3",
    "memory_type": "{build.boot}_{build.psram_type}",
    "msc_on_boot": "0",
    "partitions": "default_16MB",
    "psram_type": "opi",
    "tarch": "xtensa",
    "target": "esp32s3",
    "usb_mode": "0",
    "variant": "amyboard"
  },
  "menu": {
    "CPUFreq": {
      "160": {
        "": "160MHz (WiFi)",
        "build": {
          "f_cpu": "160000000L"
        }
      },
      "240": {
        "": "240MHz (WiFi)",
        "build": {
          "f_cpu": "240000000L"
        }
      },
      "80": {
        "": "80MHz (WiFi)",
        "build": {
          "f_cpu": "80000000L"
        }
      }
    },
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "EventsCore": {
      "0": {
        "": "Core 0",
        "build": {
          "event_core": "-DARDUINO_EVENT_RUNNING_CORE=0"
        }
      },
      "1": {
        "": "Core 1",
        "build": {
          "event_core": "-DARDUINO_EVENT_RUNNING_CORE=1"
        }
      }
    },
    "JTAGAdapter": {
      "bridge": {
        "": "ESP USB Bridge",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-bridge.cfg"
        }
      },
      "builtin": {
        "": "Integrated USB JTAG",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-builtin.cfg"
        }
      },
      "default": {
        "": "Disabled",
        "build": {
          "copy_jtag_files": "0"
        }
      },
      "external": {
        "": "FTDI Adapter",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-ftdi.cfg"
        }
      }
    },
    "LoopCore": {
      "0": {
        "": "Core 0",
        "build": {
          "loop_core": "-DARDUINO_RUNNING_CORE=0"
        }
      },
      "1": {
        "": "Core 1",
        "build": {
          "loop_core": "-DARDUINO_RUNNING_CORE=1"
        }
      }
    },
    "PartitionScheme": {
      "app3M_fat9M_16MB": {
        "": "16M Flash (3MB APP/9.9MB FATFS)",
        "build": {
          "partitions": "app3M_fat9M_16MB"
        },
        "upload": {
          "maximum_size": "3145728"
        }
      },
      "custom": {
        "": "Custom",
        "build": {
          "partitions": ""
        },
        "upload": {
          "maximum_size": "16777216"
        }
      },
      "default_16MB": {
        "": "16M with spiffs (6.25MB APP/3.43MB SPIFFS)",
        "build": {
          "partitions": "default_16MB"
        },
        "upload": {
          "maximum_size": "6553600"
        }
      },
      "fatflash": {
        "": "16M Flash (2MB APP/12.5MB FATFS)",
        "build": {
          "partitions": "ffat"
        },
        "upload": {
          "maximum_size": "2097152"
        }
      }
    },
    "UploadMode": {
      "default": {
        "": "USB-OTG CDC (TinyUSB)",
        "upload": {
          "use_1200bps_touch": "true",
          "wait_for_upload_port": "true"
        }
      },
      "uart": {
        "": "UART0 / Hardware CDC",
        "upload": {
          "use_1200bps_touch": "false",
          "wait_for_upload_port": "false"
        }
      }
    },
    "UploadSpeed": {
      "115200": {
        "": "115200",
        "upload": {
          "speed": "115200"
        }
      },
      "230400": {
        "": "230400",
        "upload": {
          "speed": "230400"
        },
        "windows": {
          "upload": {
            "speed": "256000"
          }
        }
      },
      "256000": {
        "upload": {
          "speed": "256000"
        },
        "windows": "256000"
      },
      "460800": {
        "linux": "460800",
        "macosx": "460800",
        "upload": {
          "speed": "460800"
        }
      },
      "512000": {
        "upload": {
          "speed": "512000"
        },
        "windows": "512000"
      },
      "921600": {
        "": "921600",
        "upload": {
          "speed": "921600"
        }
      }
    }
  },
  "name": "AMYboard",
  "serial": {
    "disableDTR": "false",
    "disableRTS": "false"
  },
  "upload": {
    "extra_flags": "",
    "flags": "",
    "maximum_data_size": "327680",
    "maximum_size": "6553600",
    "tool": {
      "": "esptool_py",
      "default": "esptool_py",
      "network": "esp_ota"
    },
    "use_1200bps_touch": "false",
    "wait_for_upload_port": "false"
  }
}
