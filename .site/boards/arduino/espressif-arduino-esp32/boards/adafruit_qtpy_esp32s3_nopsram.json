        "build": {
          "boot": "opi",
          "boot_freq": "80m",
          "flash_freq": "80m",
          "flash_mode": "dout"
        }
      },
      "qio": {
        "": "QIO 80MHz",
        "build": {
          "boot": "qio",
          "boot_freq": "80m",
          "flash_freq": "80m",
