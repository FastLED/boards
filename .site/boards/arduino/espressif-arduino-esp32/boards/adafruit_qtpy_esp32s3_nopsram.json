    "PartitionScheme": {
      "default_8MB": {
        "": "Default (3MB APP/1.5MB SPIFFS)",
        "build": {
          "partitions": "default_8MB"
        },
        "upload": {
          "maximum_size": "3342336"
        }
      },
      "tinyuf2": {
        "": "TinyUF2 8MB (2MB APP/3.7MB FATFS)",
        "build": {
          "custom_bootloader": "bootloader-tinyuf2",
          "partitions": "tinyuf2-partitions-8MB"
        },
        "upload": {
          "extra_flags": "0x410000 \"{runtime.platform.path}/variants/{build.variant}/tinyuf2.bin\"",
          "maximum_size": "2097152"
        }
      },
      "tinyuf2_noota": {
        "": "TinyUF2 8MB No OTA (4MB APP/3.7MB FATFS)",
        "build": {
          "custom_bootloader": "bootloader-tinyuf2",
          "partitions": "tinyuf2-partitions-8MB-noota"
        },
        "upload": {
          "extra_flags": "0x410000 \"{runtime.platform.path}/variants/{build.variant}/tinyuf2.bin\"",
          "maximum_size": "4194304"
        }
      }
    },
    "USBMode": {
      "default": {
        "": "USB-OTG (TinyUSB)",
        "build": {
          "usb_mode": "0"
        }
      },
      "hwcdc": {
        "": "Hardware CDC and JTAG",
        "build": {
          "usb_mode": "1"
        }
      }
