{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "ADAFRUIT_QTPY_ESP32S3_NOPSRAM",
    "boot": "qio",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "1",
