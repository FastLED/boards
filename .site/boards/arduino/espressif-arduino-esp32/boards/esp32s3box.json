{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "ESP32_S3_BOX",
    "boot": "qio",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "1",
    "core": "esp32",
    "defines": "-DBOARD_HAS_PSRAM",
    "dfu_on_boot": "0",
    "event_core": "-DARDUINO_EVENT_RUNNING_CORE=1",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "16MB",
    "loop_core": "-DARDUINO_RUNNING_CORE=1",
    "mcu": "esp32s3",
    "memory_type": "qio_opi",
    "msc_on_boot": "0",
    "partitions": "default",
    "tarch": "xtensa",
    "target": "esp32s3",
    "usb_mode": "1",
    "variant": "esp32s3box"
  },
  "menu": {
    "DFUOnBoot": {
      "default": {
        "": "Disabled",
        "build": {
          "dfu_on_boot": "0"
        }
      },
      "dfu": {
        "": "Enabled (Requires USB-OTG Mode)",
        "build": {
          "dfu_on_boot": "1"
        }
      }
    },
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "MSCOnBoot": {
      "default": {
        "": "Disabled",
        "build": {
          "msc_on_boot": "0"
        }
      },
      "msc": {
        "": "Enabled (Requires USB-OTG Mode)",
        "build": {
          "msc_on_boot": "1"
        }
      }
    },
    "PartitionScheme": {
      "app3M_fat9M_16MB": {
        "": "16M Flash (3MB APP/9.9MB FATFS)",
        "build": {
          "partitions": "app3M_fat9M_16MB"
        },
        "upload": {
          "maximum_size": "3145728"
        }
      },
      "custom": {
        "": "Custom",
        "build": {
          "partitions": ""
        },
        "upload": {
          "maximum_size": "16777216"
        }
      },
      "esp_sr_16": {
        "": "ESP SR 16M (3MB APP/6MB SPIFFS/3.9MB MODEL)",
        "build": {
          "partitions": "esp_sr_16"
        },
        "upload": {
          "extra_flags": "0xC10000 {build.path}/srmodels.bin",
          "maximum_size": "3145728"
        }
      },
      "rainmaker": {
        "": "RainMaker 4MB",
        "build": {
          "partitions": "rainmaker"
        },
        "upload": {
          "maximum_size": "1966080"
        }
      },
      "rainmaker_4MB": {
        "": "RainMaker 4MB No OTA",
        "build": {
          "partitions": "rainmaker_4MB_no_ota"
        },
        "upload": {
          "maximum_size": "4038656"
        }
      }
    },
    "USBMode": {
      "default": {
        "": "USB-OTG",
        "build": {
          "usb_mode": "0"
        },
        "upload": {
          "use_1200bps_touch": "true",
          "wait_for_upload_port": "true"
        }
      },
      "hwcdc": {
        "": "Hardware CDC and JTAG",
        "build": {
          "usb_mode": "1"
        },
        "upload": {
          "use_1200bps_touch": "false",
          "wait_for_upload_port": "false"
        }
      }
    }
  },
  "name": "ESP32-S3-Box",
  "serial": {
    "disableDTR": "false",
    "disableRTS": "false"
  },
  "upload": {
    "extra_flags": "",
    "flags": "",
    "maximum_data_size": "327680",
    "maximum_size": "3145728",
    "speed": "921600",
    "tool": {
      "": "esptool_py",
      "default": "esptool_py",
      "network": "esp_ota"
    },
    "use_1200bps_touch": "false",
    "wait_for_upload_port": "false"
  }
}
