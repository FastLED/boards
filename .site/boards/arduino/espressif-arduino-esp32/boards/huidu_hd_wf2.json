{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "HUIDU_HD_WF2",
    "boot": "qio",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "1",
    "core": "esp32",
    "defines": "",
    "dfu_on_boot": "0",
