{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "ESP32C3_DEV",
    "boot": "dio",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "1",
    "core": "esp32",
    "defines": "",
    "f_cpu": "160000000L",
    "flash_freq": "40m",
    "flash_mode": "dio",
    "flash_size": "16MB",
    "mcu": "esp32c3",
    "partitions": "Custom",
    "tarch": "riscv32",
    "target": "esp",
    "variant": "xteink_x4"
  },
  "menu": {
    "CPUFreq": {
      "10": {
        "": "10MHz",
        "build": {
          "f_cpu": "10000000L"
        }
      },
      "160": {
        "": "160MHz (WiFi)",
        "build": {
          "f_cpu": "160000000L"
        }
      },
      "20": {
        "": "20MHz",
        "build": {
          "f_cpu": "20000000L"
        }
      },
      "40": {
        "": "40MHz",
        "build": {
          "f_cpu": "40000000L"
        }
      },
      "80": {
        "": "80MHz (WiFi)",
        "build": {
          "f_cpu": "80000000L"
        }
      }
    },
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "FlashFreq": {
      "40": {
        "": "40MHz",
        "build": {
          "flash_freq": "40m"
        }
      },
      "80": {
        "": "80MHz",
        "build": {
          "flash_freq": "80m"
        }
      }
    },
    "FlashMode": {
      "dio": {
        "": "DIO",
        "build": {
          "boot": "dio",
          "flash_mode": "dio"
        }
      },
      "qio": {
        "": "QIO",
        "build": {
          "boot": "qio",
          "flash_mode": "dio"
        }
      }
    },
    "JTAGAdapter": {
      "bridge": {
        "": "ESP USB Bridge",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32c3-bridge.cfg"
        }
      },
      "builtin": {
        "": "Integrated USB JTAG",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32c3-builtin.cfg"
        }
      },
      "default": {
        "": "Disabled",
        "build": {
          "copy_jtag_files": "0"
        }
      },
      "external": {
        "": "FTDI Adapter",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32c3-ftdi.cfg"
        }
      }
    },
    "PartitionScheme": {
      "app3M_fat9M_16MB": {
        "": "16M Flash (3MB APP/9.9MB FATFS)",
        "build": {
          "partitions": "app3M_fat9M_16MB"
        },
        "upload": {
          "maximum_size": "3145728"
        }
      },
      "custom": {
        "": "Custom",
        "build": {
          "partitions": "partitions.csv"
        },
        "upload": {
          "maximum_size": "16777216"
        }
      },
      "fatflash": {
        "": "16M Flash (2MB APP/12.5MB FATFS)",
        "build": {
          "partitions": "ffat"
        },
        "upload": {
          "maximum_size": "2097152"
        }
      }
    },
    "ZigbeeMode": {
      "default": {
        "": "Disabled",
        "build": {
          "zigbee_libs": "",
          "zigbee_mode": ""
        }
      },
      "zczr": {
        "": "Zigbee ZCZR (coordinator/router)",
        "build": {
          "zigbee_libs": "-lesp_zb_api.zczr -lzboss_stack.zczr -lzboss_port.remote",
          "zigbee_mode": "-DZIGBEE_MODE_ZCZR"
        }
      }
    }
  },
  "name": "Xteink X4 eReader",
  "serial": {
    "disableDTR": "false",
    "disableRTS": "false"
  },
  "upload": {
    "extra_flags": "",
    "flags": "",
    "maximum_data_size": "327680",
    "maximum_size": "1310720",
    "speed": "921600",
    "tool": {
      "": "esptool_py",
      "default": "esptool_py",
      "network": "esp_ota"
    },
    "use_1200bps_touch": "false",
    "wait_for_upload_port": "false"
  }
}
