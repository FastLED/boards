    "FlashSize": {
      "8M": {
        "": "8MB (64Mb)",
        "build": {
          "flash_size": "8MB"
        }
      }
    },
    "JTAGAdapter": {
      "bridge": {
        "": "ESP USB Bridge",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-bridge.cfg"
        }
      },
      "builtin": {
        "": "Integrated USB JTAG",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-builtin.cfg"
        }
      },
      "default": {
        "": "Disabled",
        "build": {
          "copy_jtag_files": "0"
        }
      },
      "external": {
        "": "FTDI Adapter",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-ftdi.cfg"
