{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "HELTEC_WIRELESS_TRACKER_V2",
    "boot": "qio",
    "boot_freq": "80m",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "0",
    "core": "esp32",
    "defines": "-D{build.band}  -DMCU_ESP32_S3 -DHELTEC_BOARD=34 -DWIRELESS_TRACKER_V2 -DSLOW_CLK_TPYE={build.SLOW_CLK_TPYE} -DRADIO_CHIP_SX1262  -DLoRaWAN_DEBUG_LEVEL={build.LoRaWanDebugLevel} -DACTIVE_REGION=LORAMAC_{build.band} -DLORAWAN_PREAMBLE_LENGTH={build.LORAWAN_PREAMBLE_LENGTH} -DLORAWAN_DEVEUI_AUTO={build.LORAWAN_DEVEUI_AUTO} -DLORA_RX_LNA={build.LORA_RX_LNA} -D{build.LORA_FEM_TYPE} -D{build.board}",
    "dfu_on_boot": "0",
    "event_core": "",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "8MB",
    "loop_core": "",
    "mcu": "esp32s3",
    "memory_type": "{build.boot}_{build.psram_type}",
    "msc_on_boot": "0",
    "partitions": "default_8MB",
    "psram_type": "qspi",
    "tarch": "xtensa",
    "target": "esp32s3",
    "usb_mode": "1",
    "variant": "heltec_wireless_tracker_v2"
  },
  "menu": {
