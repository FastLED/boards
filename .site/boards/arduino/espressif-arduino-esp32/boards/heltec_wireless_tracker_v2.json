      },
      "default": {
        "": "Disabled",
        "build": {
          "cdc_on_boot": "0"
        }
      }
    },
    "CPUFreq": {
      "10": {
        "": "10MHz",
        "build": {
          "f_cpu": "10000000L"
        }
      },
      "160": {
        "": "160MHz (WiFi)",
        "build": {
          "f_cpu": "160000000L"
        }
      },
      "20": {
        "": "20MHz",
        "build": {
          "f_cpu": "20000000L"
        }
      },
      "240": {
