    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "EventsCore": {
      "0": {
        "": "Core 0",
        "build": {
          "event_core": "-DARDUINO_EVENT_RUNNING_CORE=0"
        }
      },
      "1": {
        "": "Core 1",
        "build": {
          "event_core": "-DARDUINO_EVENT_RUNNING_CORE=1"
        }
      }
    },
    "FlashMode": {
      "dio": {
        "": "DIO 80MHz",
