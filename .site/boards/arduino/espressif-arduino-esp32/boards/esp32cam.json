{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "ESP32_DEV",
    "bootloader_addr": "0x1000",
    "code_debug": "0",
    "core": "esp32",
    "defines": "-DBOARD_HAS_PSRAM -mfix-esp32-psram-cache-issue -mfix-esp32-psram-cache-strategy=memw",
    "extra_libs": "",
    "flash_size": "4MB",
    "mcu": "esp32",
    "partitions": "huge_app",
    "tarch": "xtensa",
    "target": "esp32",
    "variant": "esp32"
  },
  "menu": {
    "CPUFreq": {
      "10": {
        "": "10MHz (40MHz XTAL)",
        "build": {
          "f_cpu": "10000000L"
        }
      },
      "13": {
        "": "13MHz (26MHz XTAL)",
        "build": {
          "f_cpu": "13000000L"
        }
      },
      "160": {
        "": "160MHz (WiFi/BT)",
        "build": {
          "f_cpu": "160000000L"
        }
      },
      "20": {
        "": "20MHz (40MHz XTAL)",
        "build": {
          "f_cpu": "20000000L"
        }
      },
      "240": {
        "": "240MHz (WiFi/BT)",
        "build": {
          "f_cpu": "240000000L"
        }
      },
      "26": {
        "": "26MHz (26MHz XTAL)",
        "build": {
          "f_cpu": "26000000L"
        }
      },
      "40": {
        "": "40MHz (40MHz XTAL)",
        "build": {
          "f_cpu": "40000000L"
        }
      },
      "80": {
        "": "80MHz (WiFi/BT)",
        "build": {
          "f_cpu": "80000000L"
        }
      }
    },
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "FlashFreq": {
      "40": {
        "": "40MHz",
        "build": {
          "flash_freq": "40m"
        }
      },
      "80": {
        "": "80MHz",
        "build": {
          "flash_freq": "80m"
        }
      }
    },
    "FlashMode": {
      "dio": {
        "": "DIO",
        "build": {
          "boot": "dio",
          "flash_mode": "dio"
        }
      },
      "qio": {
        "": "QIO",
        "build": {
          "boot": "qio",
          "flash_mode": "dio"
        }
      }
    },
    "PartitionScheme": {
      "default": {
        "": "Regular 4MB with spiffs (1.2MB APP/1.5MB SPIFFS)",
        "build": {
          "partitions": "default"
        }
      },
      "defaultffat": {
        "": "Regular 4MB with ffat (1.2MB APP/1.5MB FATFS)",
        "build": {
          "partitions": "default_ffat"
        }
      },
      "huge_app": {
        "": "Huge APP (3MB No OTA/1MB SPIFFS)",
        "build": {
          "partitions": "huge_app"
        },
        "upload": {
          "maximum_size": "3145728"
        }
      },
      "min_spiffs": {
        "": "Minimal SPIFFS (1.9MB APP with OTA/128KB SPIFFS)",
        "build": {
          "partitions": "min_spiffs"
        },
        "upload": {
          "maximum_size": "1966080"
        }
      },
      "minimal": {
        "": "Minimal (1.3MB APP/700KB SPIFFS)",
        "build": {
          "partitions": "minimal"
        }
      },
      "no_ota": {
        "": "No OTA (2MB APP/2MB SPIFFS)",
        "build": {
          "partitions": "no_ota"
        },
        "upload": {
          "maximum_size": "2097152"
        }
      },
      "noota_3g": {
        "": "No OTA (1MB APP/3MB SPIFFS)",
        "build": {
          "partitions": "noota_3g"
        },
        "upload": {
          "maximum_size": "1048576"
        }
      },
      "noota_3gffat": {
        "": "No OTA (1MB APP/3MB FATFS)",
        "build": {
          "partitions": "noota_3gffat"
        },
        "upload": {
          "maximum_size": "1048576"
        }
      },
      "noota_ffat": {
        "": "No OTA (2MB APP/2MB FATFS)",
        "build": {
          "partitions": "noota_ffat"
        },
        "upload": {
          "maximum_size": "2097152"
        }
      }
    }
  },
  "name": "AI Thinker ESP32-CAM",
  "serial": {
    "disableDTR": "true",
    "disableRTS": "true"
  },
  "upload": {
    "extra_flags": "",
    "flags": "",
    "maximum_data_size": "327680",
    "maximum_size": "3145728",
    "speed": "460800",
    "tool": {
      "": "esptool_py",
      "default": "esptool_py",
      "network": "esp_ota"
    }
  }
}
