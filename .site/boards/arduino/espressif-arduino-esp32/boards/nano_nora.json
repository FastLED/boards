{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "NANO_ESP32",
    "boot": "qio",
    "boot_freq": "80m",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "1",
    "code_debug": "0",
    "core": "esp32",
    "defines": "-DBOARD_HAS_PIN_REMAP {build.disable_pin_remap} -DBOARD_HAS_PSRAM '-DUSB_MANUFACTURER=\"Arduino\"' '-DUSB_PRODUCT=\"Nano ESP32\"'",
    "dfu_on_boot": "1",
    "disable_pin_remap": "",
    "event_core": "-DARDUINO_EVENT_RUNNING_CORE=1",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "16MB",
    "loop_core": "-DARDUINO_RUNNING_CORE=1",
    "mcu": "esp32s3",
    "memory_type": "{build.boot}_{build.psram_type}",
    "msc_on_boot": "0",
    "partitions": "app3M_fat9M_fact512k_16MB",
    "psram_type": "opi",
    "tarch": "xtensa",
    "target": "esp32s3",
    "usb_mode": "0",
    "variant": "arduino_nano_nora"
  },
  "debug": {
    "additional_config": "debug_config.nano_nora",
    "executable": ""
  },
  "debug_config": {
    "nano_nora": {
      "cortex-debug": {
        "custom": {
          "name": "Arduino on Nano ESP32",
          "overrideAttachCommands": {
            "0": "set remote hardware-watchpoint-limit 2",
            "1": "monitor reset halt",
            "2": "monitor gdb_sync",
            "3": "interrupt"
          },
          "overrideRestartCommands": {
            "0": "monitor reset halt",
            "1": "monitor gdb_sync",
            "2": "interrupt"
          }
        }
      }
    }
  },
  "menu": {
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "PartitionScheme": {
      "default": "With FAT partition (default)",
      "spiffs": {
        "": "With SPIFFS partition (advanced)",
        "build": {
          "partitions": "app3M_spiffs9M_fact512k_16MB"
        }
      }
    },
    "PinNumbers": {
      "byGPIONumber": {
        "": "By GPIO number (legacy)",
        "build": {
          "disable_pin_remap": "-DBOARD_USES_HW_GPIO_NUMBERS"
        }
      },
      "default": "By Arduino pin (default)"
    },
    "USBMode": {
      "default": "Normal mode (TinyUSB)",
      "hwcdc": {
        "": "Debug mode (Hardware CDC)",
        "build": {
          "usb_mode": "1"
        },
        "debug": {
          "executable": "{build.path}/{build.project_name}.elf"
        }
      }
    }
  },
  "name": "Arduino Nano ESP32",
  "pid": {
    "0": "0x0070"
  },
  "serial": {
    "disableDTR": "false",
    "disableRTS": "false"
  },
  "tools": {
    "esptool_py": {
      "erase": {
        "pattern_args": "--chip {build.mcu} --port \"{serial.port}\" --before default-reset --after hard-reset erase-flash"
      },
      "program": {
        "pattern_args": "--chip {build.mcu} --port \"{serial.port}\" --before default-reset --after hard-reset write-flash -z --flash-mode {build.flash_mode} --flash-freq {build.flash_freq} --flash-size {build.flash_size} {build.bootloader_addr} \"{build.path}/{build.project_name}.bootloader.bin\" 0x8000 \"{build.path}/{build.project_name}.partitions.bin\" 0xe000 \"{runtime.platform.path}/tools/partitions/boot_app0.bin\" 0xf70000 \"{build.variant.path}/extra/nora_recovery/nora_recovery.ino.bin\" 0x10000 \"{build.path}/{build.project_name}.bin\""
      }
    }
  },
  "upload": {
    "extra_flags": "",
    "flags": "",
    "maximum_data_size": "327680",
    "maximum_size": "3145728",
    "protocol": "serial",
    "tool": {
      "": "dfu-util",
      "default": "dfu-util",
      "network": "esp_ota"
    },
    "use_1200bps_touch": "false",
    "wait_for_upload_port": "false"
  },
  "upload_port": {
    "0": {
      "pid": "0x0070",
      "vid": "0x2341"
    }
  },
  "vid": {
    "0": "0x2341"
  }
}
