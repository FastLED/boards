{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "OZOBOT_DRVKIT",
    "boot": "qio",
    "boot_freq": "80m",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "1",
    "code_debug": "0",
    "core": "esp32",
    "defines": "-DBOARD_HAS_PIN_REMAP {build.disable_pin_remap} -DBOARD_HAS_PSRAM",
    "dfu_on_boot": "0",
    "disable_pin_remap": "",
    "event_core": "",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "4MB",
    "loop_core": "",
    "mcu": "esp32s3",
    "memory_type": "{build.boot}_{build.psram_type}",
    "msc_on_boot": "0",
    "psram_type": "qspi",
    "tarch": "xtensa",
    "target": "esp32s3",
    "usb_mode": "1",
    "variant": "ozobot_drvkit"
  },
  "menu": {
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "EventsCore": {
      "0": {
        "": "Core 0",
        "build": {
          "event_core": "-DARDUINO_EVENT_RUNNING_CORE=0"
        }
      },
      "1": {
        "": "Core 1",
        "build": {
          "event_core": "-DARDUINO_EVENT_RUNNING_CORE=1"
        }
      }
    },
    "JTAGAdapter": {
      "bridge": {
        "": "ESP USB Bridge",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-bridge.cfg"
        }
      },
      "external": {
        "": "FTDI Adapter",
        "build": {
          "copy_jtag_files": "1",
          "openocdscript": "esp32s3-ftdi.cfg"
        }
      }
    },
    "LoopCore": {
      "0": {
        "": "Core 0",
        "build": {
          "loop_core": "-DARDUINO_RUNNING_CORE=0"
        }
      },
      "1": {
        "": "Core 1",
        "build": {
          "loop_core": "-DARDUINO_RUNNING_CORE=1"
        }
      }
    },
    "PartitionScheme": {
      "custom": {
        "": "Custom",
        "build": {
          "partitions": ""
        },
        "upload": {
          "maximum_size": "4194304"
        }
      },
      "default": {
        "": "Default 4MB with spiffs (1.2MB APP/1.5MB SPIFFS)",
        "build": {
          "partitions": "default"
        }
      },
      "defaultffat": {
        "": "Default 4MB with ffat (1.2MB APP/1.5MB FATFS)",
        "build": {
          "partitions": "default_ffat"
        }
      },
      "huge_app": {
        "": "Huge APP (3MB No OTA/1MB SPIFFS)",
        "build": {
          "partitions": "huge_app"
        },
        "upload": {
          "maximum_size": "3145728"
        }
      },
      "min_spiffs": {
        "": "Minimal SPIFFS (1.9MB APP with OTA/128KB SPIFFS)",
        "build": {
          "partitions": "min_spiffs"
        },
        "upload": {
          "maximum_size": "1966080"
        }
      },
      "minimal": {
        "": "Minimal (1.3MB APP/700KB SPIFFS)",
        "build": {
          "partitions": "minimal"
        }
      },
      "no_fs": {
        "": "No FS 4MB (2MB APP x2)",
        "build": {
          "partitions": "no_fs"
        },
        "upload": {
          "maximum_size": "2031616"
        }
      },
      "no_ota": {
        "": "No OTA (2MB APP/2MB SPIFFS)",
        "build": {
          "partitions": "no_ota"
        },
        "upload": {
          "maximum_size": "2097152"
        }
      },
      "noota_3g": {
        "": "No OTA (1MB APP/3MB SPIFFS)",
        "build": {
          "partitions": "noota_3g"
        },
        "upload": {
          "maximum_size": "1048576"
        }
      },
      "noota_3gffat": {
        "": "No OTA (1MB APP/3MB FATFS)",
        "build": {
          "partitions": "noota_3gffat"
        },
        "upload": {
          "maximum_size": "1048576"
        }
      },
      "noota_ffat": {
        "": "No OTA (2MB APP/2MB FATFS)",
        "build": {
          "partitions": "noota_ffat"
        },
        "upload": {
          "maximum_size": "2097152"
        }
      },
      "rainmaker": {
        "": "RainMaker 4MB",
        "build": {
          "partitions": "rainmaker"
        },
        "upload": {
          "maximum_size": "1966080"
        }
      },
      "rainmaker_4MB": {
        "": "RainMaker 4MB No OTA",
        "build": {
          "partitions": "rainmaker_4MB_no_ota"
        },
        "upload": {
          "maximum_size": "4038656"
        }
      },
      "zigbee_zczr": {
        "": "Zigbee ZCZR 4MB with spiffs",
        "build": {
          "partitions": "zigbee_zczr"
        },
        "upload": {
          "maximum_size": "1310720"
        }
      }
    },
    "PinNumbers": {
      "byGPIONumber": {
        "": "By GPIO number (legacy)",
        "build": {
          "disable_pin_remap": "-DBOARD_USES_HW_GPIO_NUMBERS"
        }
      },
      "default": "By Arduino pin (default)"
    },
    "USBMode": {
      "default": {
        "": "USB-OTG (TinyUSB)",
        "build": {
          "usb_mode": "0"
        }
      },
      "hwcdc": {
        "": "Hardware CDC and JTAG",
        "build": {
          "usb_mode": "1"
        },
        "debug": {
          "executable": "{build.path}/{build.project_name}.elf"
        }
      }
    },
    "ZigbeeMode": {
      "default": {
        "": "Disabled",
        "build": {
          "zigbee_libs": "",
          "zigbee_mode": ""
        }
      },
      "zczr": {
        "": "Zigbee ZCZR (coordinator/router)",
        "build": {
          "zigbee_libs": "-lesp_zb_api.zczr -lzboss_stack.zczr -lzboss_port.remote",
          "zigbee_mode": "-DZIGBEE_MODE_ZCZR"
        }
      }
    }
  },
  "name": "Ozobot DRVKit",
  "pid": {
    "0": "0x1901"
  },
  "serial": {
    "disableDTR": "false",
    "disableRTS": "false"
  },
  "upload": {
    "extra_flags": "",
    "flags": "",
    "maximum_data_size": "327680",
    "maximum_size": "1310720",
    "speed": "921600",
    "tool": {
      "": "esptool_py",
      "default": "esptool_py",
      "network": "esp_ota"
    },
    "use_1200bps_touch": "false",
    "wait_for_upload_port": "false"
  },
  "upload_port": {
    "0": {
      "pid": "0x1001",
      "vid": "0x303A"
    }
  },
  "vid": {
    "0": "0x2D81"
  }
}
