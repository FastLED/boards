{
  "bootloader": {
    "config": "-f target/nrf52.cfg",
    "extra_action": {
      "preflash": "echo INFO:removed_mass-erase"
    },
    "file": "nano33ble/bootloader.hex",
    "programmer": "-f interface/cmsis-dap.cfg",
    "tool": {
      "": "openocd",
      "default": "openocd"
    }
  },
  "build": {
    "architecture": "cortex-m4",
    "board": "STELLA",
    "compiler_path": "{runtime.tools.arm-none-eabi-gcc-7-2017q4.path}/bin/",
    "core": "arduino",
    "crossprefix": "arm-none-eabi-",
    "extra_flags": "",
    "float-abi": "-mfloat-abi=softfp",
    "fpu": "-mfpu=fpv4-sp-d16",
    "ldscript": "linker_script.ld",
    "mcu": "cortex-m4",
    "variant": "STELLA"
  },
  "compiler": {
    "mbed": {
      "": "\"{build.variant.path}/libs/libmbed.a\" \"{build.variant.path}/libs/libcc_310_core.a\" \"{build.variant.path}/libs/libcc_310_ext.a\" \"{build.variant.path}/libs/libcc_310_trng.a\"",
      "arch": {
        "define": "-DARDUINO_ARCH_NRF52840"
      },
      "cflags": "{build.variant.path}/cflags.txt",
      "cxxflags": "{build.variant.path}/cxxflags.txt",
      "defines": "{build.variant.path}/defines.txt",
      "extra_ldflags": "-lstdc++ -lsupc++ -lm -lc -lgcc -lnosys",
      "includes": "{build.variant.path}/includes.txt",
      "ldflags": "{build.variant.path}/ldflags.txt"
    }
  },
  "debug": {
    "server": {
      "openocd": {
        "scripts": {
          "0": "interface/{programmer.protocol}.cfg",
          "1": "{programmer.transport_script}",
          "2": "target/nrf52.cfg"
        }
      }
    },
    "svd_file": "{runtime.platform.path}/svd/nrf52840.svd"
  },
  "name": "Arduino Stella",
  "pid": {
    "0": "0x005a",
    "1": "0x0076"
  },
  "upload": {
    "maximum_data_size": "262144",
    "maximum_size": "983040",
    "native_usb": "true",
    "protocol": "",
    "tool": {
      "": "bossac",
      "default": "bossac"
    },
    "transport": "",
    "use_1200bps_touch": "true",
    "wait_for_upload_port": "true"
  },
  "upload_port": {
    "0": {
      "pid": "0x005a",
      "vid": "0x2341"
    },
    "1": {
      "pid": "0x0076",
      "vid": "0x2341"
    }
  },
  "vid": {
    "0": "0x2341",
    "1": "0x2341"
  }
}
