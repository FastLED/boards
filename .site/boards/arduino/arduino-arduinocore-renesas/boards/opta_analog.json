{
  "build": {
    "architecture": "cortex-m4",
    "board": "OPTA_ANALOG",
    "compiler_path": "{runtime.tools.arm-none-eabi-gcc-7-2017q4.path}/bin/",
    "core": "arduino",
    "crossprefix": "arm-none-eabi-",
    "defines": "-DF_CPU=48000000",
    "float-abi": "-mfloat-abi=hard",
    "fpu": "-mfpu=fpv4-sp-d16",
    "mcu": "cortex-m4",
    "variant": "OPTA_ANALOG"
  },
  "compiler": {
    "fsp": {
      "": "\"{build.variant.path}/libs/libfsp.a\"",
      "cflags": "-mthumb \"@{compiler.fsp.defines}\"",
      "cxxflags": "-mthumb \"@{compiler.fsp.defines}\"",
      "defines": "{build.variant.path}/defines.txt",
      "extra_ldflags": "--specs=nano.specs -lstdc++ -lsupc++ -lm -lc -lgcc -lnosys",
      "includes": "{build.variant.path}/includes.txt",
      "ldflags": "{build.variant.path}/ldflags.txt"
    },
    "tinyusb": {
      "cflags": "-DCFG_TUSB_MCU=OPT_MCU_RAXXX",
      "cxxflags": "-DCFG_TUSB_MCU=OPT_MCU_RAXXX"
    }
  },
  "name": "Arduino OPTA ANALOG",
  "pid": {
    "0": "0x0071",
    "1": "0x0171"
  },
  "upload": {
    "address": "0x00010000",
    "interface": "0",
    "maximum_data_size": "32768",
    "maximum_size": "262144",
    "native_usb": "true",
    "pid": "0x0171",
    "protocol": "",
    "tool": {
      "": "dfu-util",
      "default": "dfu-util"
    },
    "transport": "",
    "use_1200bps_touch": "false",
    "vid": "0x2341",
    "wait_for_upload_port": "false"
  },
  "upload_port": {
    "0": {
      "pid": "0x0071",
      "vid": "0x2341"
    },
    "1": {
      "pid": "0x0171",
      "vid": "0x2341"
    }
  },
  "vid": {
    "0": "0x2341",
    "1": "0x2341"
  }
}
