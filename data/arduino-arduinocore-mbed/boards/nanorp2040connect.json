{
  "bootloader": {
    "config": "-f target/rp2040.cfg",
    "programmer": "-f interface/cmsis-dap.cfg",
    "tool": {
      "": "openocd",
      "default": "openocd"
    }
  },
  "build": {
    "architecture": "cortex-m0plus",
    "board": "NANO_RP2040_CONNECT",
    "compiler_path": "{runtime.tools.arm-none-eabi-gcc-7-2017q4.path}/bin/",
    "core": "arduino",
    "crossprefix": "arm-none-eabi-",
    "extra_flags": "",
    "float-abi": "",
    "fpu": "",
    "ldscript": "linker_script.ld",
    "mcu": "cortex-m0plus",
    "variant": "NANO_RP2040_CONNECT"
  },
  "compiler": {
    "mbed": {
      "": "\"{build.variant.path}/libs/libmbed.a\"",
      "arch": {
        "define": "-DARDUINO_ARCH_RP2040"
      },
      "cflags": "{build.variant.path}/cflags.txt",
      "cxxflags": "{build.variant.path}/cxxflags.txt",
      "defines": "{build.variant.path}/defines.txt",
      "extra_ldflags": "-lstdc++ -lsupc++ -lm -lc -lgcc -lnosys",
      "includes": "{build.variant.path}/includes.txt",
      "ldflags": "{build.variant.path}/ldflags.txt"
    }
  },
  "debug": {
    "server": {
      "openocd": {
        "scripts": {
          "0": "interface/{programmer.protocol}.cfg",
          "1": "{programmer.transport_script}",
          "2": "target/rp2040-core0.cfg"
        }
      }
    },
    "svd_file": "{runtime.platform.path}/svd/rp2040.svd"
  },
  "name": "Arduino Nano RP2040 Connect",
  "pid": {
    "0": "0x005e",
    "1": "0x805e",
    "2": "0x015e",
    "3": "0x025e"
  },
  "recipe": {
    "hooks": {
      "objcopy": {
        "postobjcopy": {
          "1": {
            "pattern": "\"{runtime.tools.rp2040tools.path}/elf2uf2\" \"{build.path}/{build.project_name}.elf\" \"{build.path}/{build.project_name}.uf2\""
          }
        }
      }
    }
  },
  "upload": {
    "maximum_data_size": "270336",
    "maximum_size": "16777216",
    "native_usb": "true",
    "protocol": "",
    "tool": {
      "": "picotool",
      "default": "picotool"
    },
    "transport": "",
    "use_1200bps_touch": "true",
    "wait_for_upload_port": "false"
  },
  "upload_port": {
    "0": {
      "pid": "0x005e",
      "vid": "0x2341"
    },
    "1": {
      "pid": "0x805e",
      "vid": "0x2341"
    },
    "2": {
      "pid": "0x015e",
      "vid": "0x2341"
    },
    "3": {
      "pid": "0x025e",
      "vid": "0x2341"
    }
  },
  "vid": {
    "0": "0x2341",
    "1": "0x2341",
    "2": "0x2341",
    "3": "0x2341"
  }
}
