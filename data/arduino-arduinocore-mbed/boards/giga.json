{
  "bootloader": {
    "config": "-f target/stm32h7x_dual_bank.cfg",
    "extra_action": {
      "preflash": "stm32h7x option_write 0 0x01c 0xb86aaf0"
    },
    "file": "GIGA/bootloader.hex",
    "programmer": "-f interface/stlink.cfg",
    "tool": {
      "": "openocd",
      "default": "openocd"
    }
  },
  "build": {
    "alignment": "32",
    "architecture": "cortex-m7",
    "board": "GIGA",
    "compiler_path": "{runtime.tools.arm-none-eabi-gcc-7-2017q4.path}/bin/",
    "core": "arduino",
    "crossprefix": "arm-none-eabi-",
    "extra_flags": "",
    "extra_ldflags": "-DCM4_BINARY_START=0x08180000",
    "float-abi": "-mfloat-abi=softfp",
    "header_size": "0x20000",
    "ldscript": "linker_script.ld",
    "postbuild": {
      "cmd": "\"{tools.imgtool.path}/{tools.imgtool.cmd}\" exit"
    },
    "slot_size": "0x1E0000",
    "version": "1.2.3+4"
  },
  "compiler": {
    "mbed": {
      "": "\"{build.variant.path}/libs/libmbed.a\"",
      "arch": {
        "define": ""
      },
      "cflags": "{build.variant.path}/cflags.txt",
      "cxxflags": "{build.variant.path}/cxxflags.txt",
      "defines": "{build.variant.path}/defines.txt",
      "extra_ldflags": "-lstdc++ -lsupc++ -lm -lc -lgcc -lnosys",
      "includes": "{build.variant.path}/../GIGA/includes.txt",
      "ldflags": "{build.variant.path}/ldflags.txt"
    }
  },
  "debug": {
    "cortex-debug": {
      "custom": {
        "request": "attach"
      }
    },
    "server": {
      "openocd": {
        "scripts": {
          "0": "interface/{programmer.protocol}.cfg",
          "1": "{programmer.transport_script}",
          "2": "target/stm32h7x_dual_bank.cfg"
        }
      }
    },
    "tool": "gdb"
  },
  "menu": {
    "security": {
      "none": {
        "": "None",
        "upload": {
          "address_m7": "0x08040000",
          "interface": "0"
        }
      },
      "sien": {
        "": "Signature + Encryption",
        "build": {
          "keys": {
            "encrypt_key": "ecdsa-p256-encrypt-pub-key.pem",
            "keychain": "{runtime.platform.path}/libraries/MCUboot/default_keys",
            "sign_key": "ecdsa-p256-signing-priv-key.pem"
          }
        },
        "recipe": {
          "hooks": {
            "objcopy": {
              "postobjcopy": {
                "1": {
                  "pattern": "\"{tools.imgtool.path}/{tools.imgtool.cmd}\" {tools.imgtool.flags}"
                }
              }
            }
          }
        },
        "upload": {
          "address_m7": "0xA0000000",
          "interface": "2"
        }
      }
    },
    "split": {
      "100_0": {
        "": "2MB M7 + M4 in SDRAM",
        "build": {
          "extra_ldflags": "-DCM4_BINARY_START=0x60000000 -DCM4_BINARY_END=0x60040000 -DCM4_RAM_END=0x60080000"
        },
        "upload": {
          "address_m4": ""
        }
      },
      "50_50": {
        "": "1MB M7 + 1MB M4",
        "build": {
          "extra_ldflags": "-DCM4_BINARY_START=0x08100000 -DCM4_BINARY_END=0x08200000"
        },
        "upload": {
          "address_m4": "0x08100000"
        }
      },
      "75_25": {
        "": "1.5MB M7 + 0.5MB M4",
        "build": {
          "extra_ldflags": "-DCM4_BINARY_START=0x08180000 -DCM4_BINARY_END=0x08200000"
        },
        "upload": {
          "address_m4": "0x08180000"
        }
      }
    },
    "target_core": {
      "cm4": {
        "": "M4 Co-processor",
        "build": {
          "architecture": "cortex-m4",
          "fpu": "-mfpu=fpv4-sp-d16",
          "mcu": "cortex-m4",
          "variant": "GENERIC_STM32H747_M4"
        },
        "compiler": {
          "mbed": {
            "arch": {
              "define": "-DGIGA_PINS"
            }
          }
        },
        "debug": {
          "svd_file": "{runtime.platform.path}/svd/STM32H747_CM4.svd"
        },
        "menu": {
          "split": {
            "100_0": {
              "upload": {
                "maximum_size": "524288"
              }
            },
            "50_50": {
              "upload": {
                "maximum_size": "1048576"
              }
            },
            "75_25": {
              "upload": {
                "maximum_size": "524288"
              }
            }
          }
        },
        "upload": {
          "address": "{upload.address_m4}",
          "maximum_data_size": "294248"
        }
      },
      "cm7": {
        "": "Main Core",
        "build": {
          "architecture": "cortex-m7",
          "fpu": "-mfpu=fpv5-d16",
          "mcu": "cortex-m7",
          "variant": "GIGA"
        },
        "compiler": {
          "mbed": {
            "arch": {
              "define": ""
            }
          }
        },
        "debug": {
          "svd_file": "{runtime.platform.path}/svd/STM32H747_CM7.svd"
        },
        "menu": {
          "split": {
            "100_0": {
              "upload": {
                "maximum_size": "1966080"
              }
            },
            "50_50": {
              "upload": {
                "maximum_size": "786432"
              }
            },
            "75_25": {
              "upload": {
                "maximum_size": "1441792"
              }
            }
          }
        },
        "upload": {
          "address": "{upload.address_m7}",
          "maximum_data_size": "523624"
        }
      }
    }
  },
  "name": "Arduino Giga R1",
  "pid": {
    "0": "0x0266",
    "1": "0x0366",
    "2": "0x0466"
  },
  "upload": {
    "interface": "0",
    "maximum_data_size": "523624",
    "maximum_size": "1966080",
    "native_usb": "true",
    "pid": "0x0366",
    "protocol": "",
    "tool": {
      "": "dfu-util",
      "default": "dfu-util"
    },
    "transport": "",
    "use_1200bps_touch": "true",
    "vid": "0x2341",
    "wait_for_upload_port": "true"
  },
  "upload_port": {
    "0": {
      "pid": "0x0266",
      "vid": "0x2341"
    },
    "1": {
      "pid": "0x0366",
      "vid": "0x2341"
    },
    "2": {
      "pid": "0x0466",
      "vid": "0x2341"
    }
  },
  "vid": {
    "0": "0x2341",
    "1": "0x2341",
    "2": "0x2341"
  }
}
