{
  "bootloader": {
    "config": "-f target/nrf52.cfg",
    "extra_action": {
      "preflash": "echo INFO:removed_mass-erase"
    },
    "file": "NICLA_VOICE/bootloader_application.hex",
    "programmer": "-f interface/cmsis-dap.cfg",
    "tool": {
      "": "openocd",
      "default": "openocd"
    }
  },
  "build": {
    "architecture": "cortex-m4",
    "board": "NICLA",
    "compiler_path": "{runtime.tools.arm-none-eabi-gcc-7-2017q4.path}/bin/",
    "core": "arduino",
    "crossprefix": "arm-none-eabi-",
    "extra_flags": "",
    "float-abi": "-mfloat-abi=softfp",
    "fpu": "-mfpu=fpv4-sp-d16",
    "ldscript": "linker_script.ld",
    "mcu": "cortex-m4",
    "postbuild": {
      "cmd": "\"{tools.imgtool.path}/{tools.imgtool.cmd}\" exit"
    },
    "variant": "NICLA"
  },
  "compiler": {
    "mbed": {
      "": "\"{build.variant.path}/libs/libmbed.a\"",
      "arch": {
        "define": "-DARDUINO_ARCH_NRF52832"
      },
      "cflags": "{build.variant.path}/cflags.txt",
      "cxxflags": "{build.variant.path}/cxxflags.txt",
      "defines": "{build.variant.path}/defines.txt",
      "extra_ldflags": "-lstdc++ -lsupc++ -lm -lc -lgcc -lnosys",
      "includes": "{build.variant.path}/includes.txt",
      "ldflags": "{build.variant.path}/ldflags.txt"
    }
  },
  "debug": {
    "server": {
      "openocd": {
        "scripts": {
          "0": "interface/{programmer.protocol}.cfg",
          "1": "{programmer.transport_script}",
          "2": "target/nrf52.cfg"
        }
      }
    },
    "svd_file": "{runtime.platform.path}/svd/nrf52833.svd"
  },
  "name": "Arduino Nicla Voice",
  "pid": {
    "0": "0x0065"
  },
  "programmer": {
    "protocol": "cmsis-dap",
    "transport_script": "\"{runtime.platform.path}/debugger/select_swd.cfg\""
  },
  "upload": {
    "config": "-f target/nrf52.cfg",
    "maximum_data_size": "64288",
    "maximum_size": "527616",
    "native_usb": "true",
    "programmer": "-f interface/cmsis-dap.cfg",
    "protocol": "",
    "tool": {
      "": "openocd",
      "default": "openocd"
    },
    "transport": "-c \"transport select swd; adapter speed 1000\"",
    "use_1200bps_touch": "false",
    "wait_for_upload_port": "true"
  },
  "upload_port": {
    "0": {
      "pid": "0x0065",
      "vid": "0x2341"
    }
  },
  "vid": {
    "0": "0x2341"
  }
}
