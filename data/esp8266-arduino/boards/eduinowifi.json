      "all": {
        "": "All Flash Contents",
        "upload": {
          "erase_cmd": "erase_flash"
        }
      },
      "none": {
        "": "Only Sketch",
        "upload": {
          "erase_cmd": ""
        }
      },
      "sdk": {
        "": "Sketch + WiFi Settings",
        "upload": {
          "erase_cmd": "erase_region \"{build.rfcal_addr}\" 0x4000"
        }
      }
