    "mmu": {
      "3216": {
        "": "16KB cache + 32KB IRAM + 16KB 2nd Heap (not shared)",
        "build": {
          "mmuflags": "-DMMU_IRAM_SIZE=0x8000 -DMMU_ICACHE_SIZE=0x4000 -DMMU_SEC_HEAP=0x40108000 -DMMU_SEC_HEAP_SIZE=0x4000"
        }
      },
      "3232": {
        "": "32KB cache + 32KB IRAM (balanced)",
        "build": {
          "mmuflags": "-DMMU_IRAM_SIZE=0x8000 -DMMU_ICACHE_SIZE=0x8000"
        }
      },
      "4816": {
        "": "16KB cache + 48KB IRAM (IRAM)",
        "build": {
          "mmuflags": "-DMMU_IRAM_SIZE=0xC000 -DMMU_ICACHE_SIZE=0x4000"
        }
      },
      "4816H": {
        "": "16KB cache + 48KB IRAM and 2nd Heap (shared)",
        "build": {
          "mmuflags": "-DMMU_IRAM_SIZE=0xC000 -DMMU_ICACHE_SIZE=0x4000 -DMMU_IRAM_HEAP"
        }
      },
      "ext128k": {
        "": "128K Heap External 23LC1024",
        "build": {
          "mmuflags": "-DMMU_EXTERNAL_HEAP=128 -DMMU_IRAM_SIZE=0x8000 -DMMU_ICACHE_SIZE=0x8000"
        }
      },
      "ext8192k": {
        "": "8M w/256K Heap External 64 MBit PSRAM",
        "build": {
          "mmuflags": "-DMMU_EXTERNAL_HEAP=256 -DMMU_IRAM_SIZE=0x8000 -DMMU_ICACHE_SIZE=0x8000"
        }
      }
    },
    "non32xfer": {
      "fast": {
        "": "Use pgm_read macros for IRAM/PROGMEM",
        "build": {
          "non32xferflags": ""
        }
      },
      "safe": {
        "": "Byte/Word access to IRAM/PROGMEM (very slow)",
        "build": {
          "non32xferflags": "-DNON32XFER_HANDLER"
        }
      }
    },
    "optim": {
      "Full": {
        "": "Optimum",
        "build": {
          "debug_optim": "-Og"
        }
      },
      "Lite": {
        "": "Lite",
        "build": {
          "debug_optim": "-Os -fno-optimize-sibling-calls"
        }
      },
      "Smallest": {
        "": "None",
        "build": {
          "debug_optim": "-Os"
        }
      }
    },
    "ssl": {
      "all": {
        "": "All SSL ciphers (most compatible)",
        "build": {
          "sslflags": ""
        }
      },
      "basic": {
        "": "Basic SSL ciphers (lower ROM use)",
        "build": {
          "sslflags": "-DBEARSSL_SSL_BASIC"
        }
      }
    },
