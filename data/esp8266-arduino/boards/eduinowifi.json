  "name": "Schirmilabs Eduino WiFi",
  "serial": {
    "disableDTR": "true",
    "disableRTS": "true"
  },
  "upload": {
    "erase_cmd": "",
    "maximum_data_size": "81920",
    "resetmethod": "--before default_reset --after hard_reset",
    "tool": "esptool",
    "wait_for_upload_port": "true"
  }
}
