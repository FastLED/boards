{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "HT_DE01",
    "boot": "qio",
    "boot_freq": "80m",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "0",
    "core": "esp32",
    "defines": "-DEINK={build.einksize}   -D{build.board}",
    "dfu_on_boot": "0",
    "event_core": "",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "8MB",
    "loop_core": "",
    "mcu": "esp32s3",
    "memory_type": "{build.boot}_{build.psram_type}",
    "msc_on_boot": "0",
    "partitions": "default_8MB",
    "psram_type": "qspi",
    "tarch": "xtensa",
    "target": "esp32s3",
    "usb_mode": "1",
    "variant": "heltec_ht_de01"
  },
