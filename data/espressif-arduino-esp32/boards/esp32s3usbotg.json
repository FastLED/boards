{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "ESP32_S3_USB_OTG",
    "boot": "qio",
    "bootloader_addr": "0x0",
    "cdc_on_boot": "0",
    "core": "esp32",
    "defines": "",
    "dfu_on_boot": "0",
    "event_core": "-DARDUINO_EVENT_RUNNING_CORE=1",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "8MB",
    "loop_core": "-DARDUINO_RUNNING_CORE=1",
    "mcu": "esp32s3",
    "memory_type": "qio_qspi",
    "msc_on_boot": "0",
    "partitions": "default",
    "tarch": "xtensa",
    "target": "esp32s3",
    "usb_mode": "0",
    "variant": "esp32s3usbotg"
  },
  "menu": {
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "PartitionScheme": {
      "custom": {
        "": "Custom",
        "build": {
          "partitions": ""
        },
        "upload": {
          "maximum_size": "8388608"
        }
      },
      "default": {
        "": "Default 4MB with spiffs (1.2MB APP/1.5MB SPIFFS)",
        "build": {
          "partitions": "default"
        }
      },
