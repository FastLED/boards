    "USBMode": {
      "default": {
        "": "USB-OTG",
        "build": {
          "cdc_on_boot": "0",
          "usb_mode": "0"
        }
      },
      "hwcdc": {
        "": "Hardware CDC and JTAG",
        "build": {
          "cdc_on_boot": "1",
          "usb_mode": "1"
        }
      }
    },
    "UploadMode": {
      "cdc": {
        "": "USB-OTG CDC (TinyUSB)",
        "upload": {
          "use_1200bps_touch": "true",
          "wait_for_upload_port": "true"
        }
      },
      "default": {
        "": "UART0 / Hardware CDC",
        "upload": {
          "use_1200bps_touch": "false",
          "wait_for_upload_port": "false"
        }
      }
    }
  },
  "name": "ESP32-S3-USB-OTG",
  "serial": {
    "disableDTR": "false",
    "disableRTS": "false"
