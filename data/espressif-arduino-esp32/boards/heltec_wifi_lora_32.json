{
  "bootloader": {
    "tool": {
      "": "esptool_py",
      "default": "esptool_py"
    }
  },
  "build": {
    "board": "HELTEC_WIFI_LORA_32",
    "boot": "qio",
    "bootloader_addr": "0x1000",
    "core": "esp32",
    "defines": "-D{build.band} -DMCU_ESP32_D0 -DWIFI_LORA_32 -DHELTEC_BOARD=1 -DRADIO_CHIP_SX127X -DSLOW_CLK_TPYE=0 -DLoRaWAN_DEBUG_LEVEL={build.LoRaWanDebugLevel} -DACTIVE_REGION=LORAMAC_{build.band} -DLORAWAN_PREAMBLE_LENGTH={build.LORAWAN_PREAMBLE_LENGTH}  -DLORAWAN_DEVEUI_AUTO={build.LORAWAN_DEVEUI_AUTO}  {build.psram}",
    "f_cpu": "240000000L",
    "flash_freq": "80m",
    "flash_mode": "dio",
    "flash_size": "4MB",
    "mcu": "esp32",
    "partitions": "default",
    "psram": "",
    "tarch": "xtensa",
    "target": "esp32",
    "variant": "heltec_wifi_lora_32"
  },
  "menu": {
    "CPUFreq": {
      "160": {
        "": "160MHz (WiFi/BT)",
        "build": {
          "f_cpu": "160000000L"
        }
      },
      "240": {
        "": "240MHz (WiFi/BT)",
        "build": {
          "f_cpu": "240000000L"
        }
      },
      "80": {
        "": "80MHz (WiFi/BT)",
        "build": {
          "f_cpu": "80000000L"
        }
      }
    },
    "DebugLevel": {
      "debug": {
        "": "Debug",
        "build": {
          "code_debug": "4"
        }
      },
      "error": {
        "": "Error",
        "build": {
          "code_debug": "1"
        }
      },
      "info": {
        "": "Info",
        "build": {
          "code_debug": "3"
        }
      },
      "none": {
        "": "None",
        "build": {
          "code_debug": "0"
        }
      },
      "verbose": {
        "": "Verbose",
        "build": {
          "code_debug": "5"
        }
      },
      "warn": {
        "": "Warn",
        "build": {
          "code_debug": "2"
        }
      }
    },
    "EraseFlash": {
      "all": {
        "": "Enabled",
        "upload": {
          "erase_cmd": "-e"
        }
      },
      "none": {
        "": "Disabled",
        "upload": {
          "erase_cmd": ""
        }
      }
    },
    "LORAWAN_DEVEUI": {
      "0": {
        "": "CUSTOM",
        "build": {
          "LORAWAN_DEVEUI_AUTO": "0"
        }
      },
      "1": {
        "": "Generate By ChipID",
        "build": {
          "LORAWAN_DEVEUI_AUTO": "1"
        }
      }
    },
    "LORAWAN_PREAMBLE_LENGTH": {
      "0": {
        "": "8(default)",
        "build": {
          "LORAWAN_PREAMBLE_LENGTH": "8"
        }
      },
      "1": {
        "": "16(For M00 and M00L)",
        "build": {
          "LORAWAN_PREAMBLE_LENGTH": "16"
        }
      }
    },
    "LORAWAN_REGION": {
