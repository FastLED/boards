  "name": "Heltec WiFi LoRa 32",
  "serial": {
    "disableDTR": "true",
    "disableRTS": "true"
  },
  "upload": {
    "extra_flags": "",
    "flags": "",
    "maximum_data_size": "327680",
    "maximum_size": "1310720",
    "tool": {
      "": "esptool_py",
      "default": "esptool_py",
      "network": "esp_ota"
    }
  }
}
