        "build": {
          "band": "REGION_US915"
        }
      },
      "4": {
        "": "REGION_AU915",
        "build": {
          "band": "REGION_AU915"
        }
      },
      "5": {
        "": "REGION_CN779",
        "build": {
          "band": "REGION_CN779"
        }
      },
      "6": {
        "": "REGION_AS923",
        "build": {
          "band": "REGION_AS923"
