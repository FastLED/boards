{
  "build": {
    "board": "GenWB0",
    "core": "arduino",
    "flash_offset": "0x0",
    "mcu": "cortex-m0plus",
    "series": "STM32WB0x",
    "st_extra_flags": "-D{build.product_line} {build.xSerial} -D__CORTEX_SC=0"
  },
  "menu": {
    "dbg": {
      "enable_all": {
        "": "Core Logs and Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g"
          }
        }
      },
      "enable_log": {
        "": "Core logs Enabled",
        "build": {
          "flags": {
            "debug": ""
          }
        }
      },
      "enable_sym": {
        "": "Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g -DNDEBUG"
          }
        }
      },
      "none": "None"
    },
    "opt": {
      "o0std": {
        "": "No Optimization (-O0)",
        "build": {
          "flags": {
            "optimize": "-O0"
          }
        }
      },
      "o1lto": {
        "": "Fast (-O1) with LTO",
        "build": {
          "flags": {
            "optimize": "-O1 -flto"
          }
        }
      },
      "o1std": {
        "": "Fast (-O1)",
        "build": {
          "flags": {
            "optimize": "-O1"
          }
        }
      },
      "o2lto": {
        "": "Faster (-O2) with LTO",
        "build": {
          "flags": {
            "optimize": "-O2 -flto"
          }
        }
      },
      "o2std": {
        "": "Faster (-O2)",
        "build": {
          "flags": {
            "optimize": "-O2"
          }
        }
      },
      "o3lto": {
        "": "Fastest (-O3) with LTO",
        "build": {
          "flags": {
            "optimize": "-O3 -flto"
          }
        }
      },
      "o3std": {
        "": "Fastest (-O3)",
        "build": {
          "flags": {
            "optimize": "-O3"
          }
        }
      },
      "ogstd": {
        "": "Debug (-Og)",
        "build": {
          "flags": {
            "optimize": "-Og"
          }
        }
      },
      "oslto": {
        "": "Smallest (-Os) with LTO",
        "build": {
          "flags": {
            "optimize": "-Os -flto"
          }
        }
      },
      "osstd": "Smallest (-Os default)"
    },
    "pnum": {
      "GENERIC_WB05KZVX": {
        "": "Generic WB05KZVx",
        "build": {
          "board": "GENERIC_WB05KZVX",
          "product_line": "STM32WB05",
          "variant": "STM32WB0x/WB05KZV_WB05TZF_WB09KEV_WB09TEF"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WB0x/STM32WB05.svd"
        },
        "upload": {
          "maximum_data_size": "24576",
          "maximum_size": "196608"
        }
      },
      "GENERIC_WB05TZFX": {
        "": "Generic WB05TZFx",
        "build": {
          "board": "GENERIC_WB05TZFX",
          "product_line": "STM32WB05",
          "variant": "STM32WB0x/WB05KZV_WB05TZF_WB09KEV_WB09TEF"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WB0x/STM32WB05.svd"
        },
        "upload": {
          "maximum_data_size": "24576",
          "maximum_size": "196608"
        }
      },
      "GENERIC_WB09KEVX": {
        "": "Generic WB09KEVx",
        "build": {
          "board": "GENERIC_WB09KEVX",
          "product_line": "STM32WB09",
          "variant": "STM32WB0x/WB05KZV_WB05TZF_WB09KEV_WB09TEF"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WB0x/STM32WB09.svd"
        },
        "upload": {
          "maximum_data_size": "65536",
          "maximum_size": "524288"
        }
      },
      "GENERIC_WB09TEFX": {
        "": "Generic WB09TEFx",
        "build": {
          "board": "GENERIC_WB09TEFX",
          "product_line": "STM32WB09",
          "variant": "STM32WB0x/WB05KZV_WB05TZF_WB09KEV_WB09TEF"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WB0x/STM32WB09.svd"
        },
        "upload": {
          "maximum_data_size": "65536",
          "maximum_size": "524288"
        }
      }
    },
    "rtlib": {
      "full": {
        "": "Newlib Standard",
        "build": {
          "flags": {
            "ldspecs": ""
          }
        }
      },
      "nano": "Newlib Nano (default)",
      "nanofp": {
        "": "Newlib Nano + Float Printf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float"
          }
        }
      },
      "nanofps": {
        "": "Newlib Nano + Float Printf/Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float -u _scanf_float"
          }
        }
      },
      "nanofs": {
        "": "Newlib Nano + Float Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _scanf_float"
          }
        }
      }
    },
    "upload_method": {
      "jlinkMethod": {
        "": "STM32CubeProgrammer (J-Link)",
        "upload": {
          "options": "-a {upload.address} -s {upload.start}",
          "protocol": "jlink",
          "tool": "stm32CubeProg"
        }
      },
      "serialMethod": {
        "": "STM32CubeProgrammer (Serial)",
        "upload": {
          "options": "-c {serial.port.file} -a {upload.address} -s {upload.start} --parity {upload.parity}",
          "protocol": "serial",
          "tool": "stm32CubeProg"
        }
      },
      "swdMethod": {
        "": "STM32CubeProgrammer (SWD)",
        "upload": {
          "options": "-a {upload.address} -m {upload.mode} -s {upload.start}",
          "protocol": "swd",
          "tool": "stm32CubeProg"
        }
      }
    },
    "xserial": {
      "disabled": {
        "": "Disabled (no Serial support)",
        "build": {
          "xSerial": ""
        }
      },
      "generic": "Enabled (generic 'Serial')",
      "none": {
        "": "Enabled (no generic 'Serial')",
        "build": {
          "xSerial": "-DHAL_UART_MODULE_ENABLED -DHWSERIAL_NONE"
        }
      }
    }
  },
  "name": "Generic STM32WB0 series",
  "openocd": {
    "target": "stm32wb0x"
  },
  "upload": {
    "address": "0x10040000",
    "maximum_data_size": "0",
    "maximum_size": "0",
    "mode": "hwRstPulse",
    "parity": "none",
    "start": "0x10000000"
  }
}
