{
  "build": {
    "board": "GenWL3",
    "core": "arduino",
    "flash_offset": "0x0",
    "mcu": "cortex-m0plus",
    "series": "STM32WL3x",
    "st_extra_flags": "-D{build.product_line} {build.xSerial} -D__CORTEX_SC=0"
  },
  "menu": {
    "dbg": {
      "enable_all": {
        "": "Core Logs and Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g"
          }
        }
      },
      "enable_log": {
        "": "Core logs Enabled",
        "build": {
          "flags": {
            "debug": ""
          }
        }
      },
      "enable_sym": {
        "": "Symbols Enabled (-g)",
        "build": {
          "flags": {
            "debug": "-g -DNDEBUG"
          }
        }
      },
      "none": "None"
    },
    "opt": {
      "o0std": {
        "": "No Optimization (-O0)",
        "build": {
          "flags": {
            "optimize": "-O0"
          }
        }
      },
      "o1lto": {
        "": "Fast (-O1) with LTO",
        "build": {
          "flags": {
            "optimize": "-O1 -flto"
          }
        }
      },
      "o1std": {
        "": "Fast (-O1)",
        "build": {
          "flags": {
            "optimize": "-O1"
          }
        }
      },
      "o2lto": {
        "": "Faster (-O2) with LTO",
        "build": {
          "flags": {
            "optimize": "-O2 -flto"
          }
        }
      },
      "o2std": {
        "": "Faster (-O2)",
        "build": {
          "flags": {
            "optimize": "-O2"
          }
        }
      },
      "o3lto": {
        "": "Fastest (-O3) with LTO",
        "build": {
          "flags": {
            "optimize": "-O3 -flto"
          }
        }
      },
      "o3std": {
        "": "Fastest (-O3)",
        "build": {
          "flags": {
            "optimize": "-O3"
          }
        }
      },
      "ogstd": {
        "": "Debug (-Og)",
        "build": {
          "flags": {
            "optimize": "-Og"
          }
        }
      },
      "oslto": {
        "": "Smallest (-Os) with LTO",
        "build": {
          "flags": {
            "optimize": "-Os -flto"
          }
        }
      },
      "osstd": "Smallest (-Os default)"
    },
    "pnum": {
      "GENERIC_WL33C8VX": {
        "": "Generic WL33C8Vx",
        "build": {
          "board": "GENERIC_WL33C8VX",
          "product_line": "STM32WL3XX",
          "variant": "STM32WL3x/WL33C(8-B-C)Vx(X)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WL3x/STM32WL33.svd"
        },
        "upload": {
          "maximum_data_size": "16384",
          "maximum_size": "65536"
        }
      },
      "GENERIC_WL33C8VXX": {
        "": "Generic WL33C8VxX",
        "build": {
          "board": "GENERIC_WL33C8VXX",
          "product_line": "STM32WL3XX",
          "variant": "STM32WL3x/WL33C(8-B-C)Vx(X)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WL3x/STM32WL33.svd"
        },
        "upload": {
          "maximum_data_size": "16384",
          "maximum_size": "65536"
        }
      },
      "GENERIC_WL33CBVX": {
        "": "Generic WL33CBVx",
        "build": {
          "board": "GENERIC_WL33CBVX",
          "product_line": "STM32WL3XX",
          "variant": "STM32WL3x/WL33C(8-B-C)Vx(X)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WL3x/STM32WL33.svd"
        },
        "upload": {
          "maximum_data_size": "32768",
          "maximum_size": "131072"
        }
      },
      "GENERIC_WL33CBVXX": {
        "": "Generic WL33CBVxX",
        "build": {
          "board": "GENERIC_WL33CBVXX",
          "product_line": "STM32WL3XX",
          "variant": "STM32WL3x/WL33C(8-B-C)Vx(X)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WL3x/STM32WL33.svd"
        },
        "upload": {
          "maximum_data_size": "32768",
          "maximum_size": "131072"
        }
      },
      "GENERIC_WL33CCVX": {
        "": "Generic WL33CCVx",
        "build": {
          "board": "GENERIC_WL33CCVX",
          "product_line": "STM32WL3XX",
          "variant": "STM32WL3x/WL33C(8-B-C)Vx(X)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WL3x/STM32WL33.svd"
        },
        "upload": {
          "maximum_data_size": "32768",
          "maximum_size": "262144"
        }
      },
      "GENERIC_WL33CCVXX": {
        "": "Generic WL33CCVxX",
        "build": {
          "board": "GENERIC_WL33CCVXX",
          "product_line": "STM32WL3XX",
          "variant": "STM32WL3x/WL33C(8-B-C)Vx(X)"
        },
        "debug": {
          "svd_file": "{runtime.tools.STM32_SVD.path}/svd/STM32WL3x/STM32WL33.svd"
        },
        "upload": {
          "maximum_data_size": "32768",
          "maximum_size": "262144"
        }
      }
    },
    "rtlib": {
      "full": {
        "": "Newlib Standard",
        "build": {
          "flags": {
            "ldspecs": ""
          }
        }
      },
      "nano": "Newlib Nano (default)",
      "nanofp": {
        "": "Newlib Nano + Float Printf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float"
          }
        }
      },
      "nanofps": {
        "": "Newlib Nano + Float Printf/Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _printf_float -u _scanf_float"
          }
        }
      },
      "nanofs": {
        "": "Newlib Nano + Float Scanf",
        "build": {
          "flags": {
            "ldspecs": "--specs=nano.specs -u _scanf_float"
          }
        }
      }
    },
    "upload_method": {
      "jlinkMethod": {
        "": "STM32CubeProgrammer (J-Link)",
        "upload": {
          "options": "-a {upload.address} -s {upload.start}",
          "protocol": "jlink",
          "tool": "stm32CubeProg"
        }
      },
      "serialMethod": {
        "": "STM32CubeProgrammer (Serial)",
        "upload": {
          "options": "-c {serial.port.file} -a {upload.address} -s {upload.start} --parity {upload.parity}",
          "protocol": "serial",
          "tool": "stm32CubeProg"
        }
      },
      "swdMethod": {
        "": "STM32CubeProgrammer (SWD)",
        "upload": {
          "options": "-a {upload.address} -m {upload.mode} -s {upload.start}",
          "protocol": "swd",
          "tool": "stm32CubeProg"
        }
      }
    },
    "xserial": {
      "disabled": {
        "": "Disabled (no Serial support)",
        "build": {
          "xSerial": ""
        }
      },
      "generic": "Enabled (generic 'Serial')",
      "none": {
        "": "Enabled (no generic 'Serial')",
        "build": {
          "xSerial": "-DHAL_UART_MODULE_ENABLED -DHWSERIAL_NONE"
        }
      }
    }
  },
  "name": "Generic STM32WL3 series",
  "openocd": {
    "target": "stm32wl3x"
  },
  "upload": {
    "address": "0x10040000",
    "maximum_data_size": "0",
    "maximum_size": "0",
    "mode": "hwRstPulse",
    "parity": "none",
    "start": "0x10000000"
  }
}
