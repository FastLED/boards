{
  "build": {
    "board": "GENERIC_RP2350",
    "boot2": "none",
    "core": "rp2040",
    "f_cpu": "125000000",
    "ldscript": "memmap_default.ld",
    "led": "",
    "usb_manufacturer": "\"Generic\"",
    "usb_product": "\"RP2350\"",
    "usbpid": "-DUSBD_PID=0xf00f",
    "usbpwr": "-DUSBD_MAX_POWER_MA=250",
    "usbvid": "-DUSBD_VID=0x2e8a",
    "variant": "generic_rp2350"
  },
  "menu": {
    "arch": {
      "arm": {
        "": "ARM",
        "build": {
          "chip": "rp2350",
          "mcu": "cortex-m33",
          "toolchain": "arm-none-eabi",
          "toolchainopts": "-mcpu=cortex-m33 -mthumb -march=armv8-m.main+fp+dsp -mfloat-abi=softfp -mcmse",
          "toolchainpkg": "pqt-gcc",
          "uf2family": "--family rp2350-arm-s --abs-block"
        }
      },
      "riscv": {
        "": "RISC-V",
        "build": {
          "chip": "rp2350-riscv",
          "mcu": "rv32imac",
          "toolchain": "riscv32-unknown-elf",
          "toolchainopts": "-march=rv32imac_zicsr_zifencei_zba_zbb_zbs_zbkb -mabi=ilp32",
          "toolchainpkg": "pqt-gcc-riscv",
          "uf2family": "--family rp2350-riscv --abs-block"
        }
      }
    },
